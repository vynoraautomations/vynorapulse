# Frontend Environment Variables

# API Configuration
# Set this in Vercel or your deployment platform if you want to override the default backend.
VITE_API_BASE_URL=https://vynora-pulse-api.onrender.com

# Supabase Configuration
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
