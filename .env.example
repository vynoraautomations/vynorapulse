# =========================

# APP CONFIG

# =========================

ENVIRONMENT=development
API_BASE_URL=http://127.0.0.1:8000
APP_SECRET_KEY=change-this-development-secret

FRONTEND_URL=http://127.0.0.1:5173
BACKEND_URL=http://127.0.0.1:8000

POLL_INTERVAL_SECONDS=60

# DATABASE

# =========================

DATABASE_URL=sqlite:///./mailalert.db


# GROQ AI

# =========================

GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant


# GMAIL OAUTH

# =========================

GMAIL_CLIENT_ID=replace-with-your-google-client-id
GMAIL_CLIENT_SECRET=replace-with-your-google-client-secret

GMAIL_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback


# SUPABASE

# =========================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# =========================

# RAZORPAY

# =========================

RAZORPAY_KEY_ID=replace-with-your-razorpay-key-id
RAZORPAY_SECRET=replace-with-your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=change-this-webhook-secret

STRIPE_SUCCESS_URL=http://127.0.0.1:5173/subscription?payment=success
STRIPE_CANCEL_URL=http://127.0.0.1:5173/subscription?payment=cancelled
WA_WEB_SERVICE_URL=http://127.0.0.1:3001

# Admin control
ADMIN_EMAIL=vynoraautomations@gmail.com
ADMIN_INITIAL_PASSWORD=change-this-admin-password
WHATSAPP_PHONE_NUMBER=+8106944811

# Plan pricing overrides
PLAN_STUDENT_BASIC_PRICE=29
PLAN_STUDENT_PRO_PRICE=79
PLAN_PROFESSIONAL_PRICE=99
PLAN_BUSINESS_PRICE=199

# =========================

# WHATSAPP WEB JS

# =========================

WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_ADMIN_NUMBER=8106944811
